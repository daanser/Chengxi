---
import Layout from "../../layouts/Layout.astro";
import SlidingImagesLoaderComponent from "../../components/playground/slidingImgesLoader";
import { SITE } from "../../site-config";
---

<script>
  import { animate, type AnimationSequence } from "motion";
  import { loaderAnimation } from "../../lib/constants";

  animate([loaderAnimation] as AnimationSequence);
</script>

<Layout
  title={`${SITE.author.fullName} - Playground - Sliding images loader`}
  description="Cool sliding images initial loader"
>
  <div class="flex flex-col items-start min-h-screen w-full p-4 relative">
    <a
      href="/playground"
      class="text-white bg-neutral-900 hover:bg-neutral-800 w-fit px-4 py-2 mb-4 border-1 border-solid border-neutral-600 rounded-lg z-20"
      >Back</a
    >

    <div class="w-full flex-1 flex justify-center items-center">
      <SlidingImagesLoaderComponent client:load />
    </div>
  </div>
</Layout>
