---
import Globe from "../components/Globe";
import BasicLayout from "../layouts/BasicLayout.astro";
import { SITE } from "../site-config";
---

<script>
  import { animate, type AnimationSequence } from "motion";

  const sequence = [
    [
      ".loaderRef",
      { opacity: [1, 0], pointerEvents: "none" },
      { type: "spring", ease: "easeOut" },
    ],
  ];

  animate(sequence as AnimationSequence);
</script>

<BasicLayout
  description="A 3d globe showing countries that you have visited so far"
  page="travel"
  title={`${SITE.author.fullName} - Visited Countries`}
>
  <a
    class="text-white fixed md:absolute bg-neutral-900 hover:bg-neutral-800 top-4 left-4 px-4 py-2 border-1 border-solid border-neutral-600 rounded-lg z-10"
    href="/">Back</a
  >

  <div class="w-full h-[60vh] min-h-[400px] md:h-[500px]">
    <Globe client:load enableHover={true} />
  </div>

  <div class="relative md:absolute md:bottom-12 left-0 right-0 flex flex-col items-center gap-2 px-4 py-4 md:py-0">
    <p class="text-xs sm:text-sm text-neutral-300 text-center">
      China · Hong Kong · Macau · UAE · South Korea · Thailand · Singapore · Japan
    </p>
    <p class="text-[10px] sm:text-xs text-neutral-500 text-center">
      地图仅展示旅行足迹，不代表任何政治立场
    </p>
  </div>
</BasicLayout>
