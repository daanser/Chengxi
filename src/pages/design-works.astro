---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import MustangIllustration from "../assets/illustrations/mustangs.webp";
import RifleIllustration from "../assets/illustrations/rifle.webp";
import SniperIllustration from "../assets/illustrations/sniper.webp";
import ShieldLogoIllustration from "../assets/illustrations/shield_logo.webp";
import RomanShieldIllustration from "../assets/illustrations/roman_shield.webp";
import RemoteControlIllustration from "../assets/illustrations/remote_control.webp";
import ProspectiveIllustration from "../assets/illustrations/prospective.webp";
import Landscape1Illustration from "../assets/illustrations/landscape_1.webp";
import Landscape2Illustration from "../assets/illustrations/landscape_2.webp";
import StockMarketDownIllustration from "../assets/illustrations/stock_market_down.webp";
import StockMarketUpIllustration from "../assets/illustrations/stock_market_up.webp";
import HouseIllustration from "../assets/illustrations/house.webp";
import BoneLogoExplorationIllustration from "../assets/illustrations/bone_logo_exploration.webp";
import HexElementIllustration1 from "../assets/illustrations/hex_element_1.png";
import HexElementIllustration2 from "../assets/illustrations/hex_element_2.png";
import { SITE } from "../site-config";
---

<script>
  import { animate, type AnimationSequence } from "motion";
  import { loaderAnimation } from "../lib/constants";

  animate([loaderAnimation] as AnimationSequence);
</script>

<Layout
  title={`${SITE.author.fullName} - Design works`}
  description="A collection of some of my design works"
>
  <div class="flex flex-col justify-center items-center p-4 pt-20 md:pt-40">
    <a
      href="/"
      class="fixed top-4 left-4 md:top-10 md:left-10 z-10 text-white bg-neutral-900 hover:bg-neutral-800 w-fit px-4 py-2 border-1 border-solid border-neutral-600 rounded-lg text-sm md:text-base"
      >← Back</a
    >
    <p class="text-white mb-6 md:mb-10 text-sm md:text-base text-center px-2">
      here you can see some of the illustrations/logos/exploration/graphic stuff
      I did during the years.
    </p>

    <div class="w-full max-w-6xl grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 px-2">
      <Image
        src={MustangIllustration}
        class="w-full aspect-square rounded-md object-cover"
        alt="mustangs illustration"
        loading="eager"
        decoding="auto"
      />
      <Image
        src={HexElementIllustration1}
        class="w-full aspect-square rounded-md object-cover"
        alt="hex element 1 illustration"
        loading="eager"
        decoding="auto"
      />
      <Image
        src={HexElementIllustration2}
        class="w-full aspect-square rounded-md object-cover"
        alt="hex element 2 illustration"
        loading="eager"
        decoding="auto"
      />
      <Image
        src={SniperIllustration}
        class="w-full aspect-square rounded-md object-cover"
        alt="sniper illustration"
        loading="eager"
        decoding="auto"
      />
      <Image
        src={RifleIllustration}
        class="w-full aspect-square rounded-md object-cover"
        alt="rifle illustration"
        loading="eager"
        decoding="auto"
      />
      <Image
        src={ShieldLogoIllustration}
        class="w-full aspect-square rounded-md object-cover"
        alt="shield logo illustration"
        loading="eager"
        decoding="auto"
      />
      <Image
        src={RomanShieldIllustration}
        class="w-full aspect-square rounded-md object-cover"
        alt="roman shield illustration"
        loading="eager"
        decoding="auto"
      />
      <Image
        src={RemoteControlIllustration}
        class="w-full aspect-square rounded-md object-cover"
        alt="remote control illustration"
        loading="eager"
        decoding="auto"
      />
      <Image
        src={ProspectiveIllustration}
        class="w-full aspect-square rounded-md object-cover"
        alt="prospective illustration"
        loading="eager"
        decoding="auto"
      />
      <Image
        src={Landscape1Illustration}
        class="w-full aspect-square rounded-md object-cover"
        alt="landscape 1 illustration"
        loading="eager"
        decoding="auto"
      />
      <Image
        src={Landscape2Illustration}
        class="w-full aspect-square rounded-md object-cover"
        alt="landscape 2 illustration"
        loading="eager"
        decoding="auto"
      />
      <Image
        src={StockMarketDownIllustration}
        class="w-full aspect-square rounded-md object-cover"
        alt="stock market down illustration"
        loading="eager"
        decoding="auto"
      />
      <Image
        src={StockMarketUpIllustration}
        class="w-full aspect-square rounded-md object-cover"
        alt="stock market up illustration"
        loading="eager"
        decoding="auto"
      />
      <Image
        src={HouseIllustration}
        class="w-full aspect-square rounded-md object-cover"
        alt="house illustration"
        loading="eager"
        decoding="auto"
      />
      <Image
        src={BoneLogoExplorationIllustration}
        class="w-full aspect-square rounded-md object-cover"
        alt="bone logo exploration"
        loading="eager"
        decoding="auto"
      />
    </div>
  </div>
</Layout>
