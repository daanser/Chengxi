---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card/index.astro";
import IntroCard from "../components/IntroCard.astro";
import ContactsCard from "../components/ContactsCard.astro";
import ThemeChangeCard from "../components/ThemeChangeCard.astro";
import TimeZone from "../components/TimeZoneCard.astro";
import AboutMe from "../components/AboutMe.astro";
import Now from "../components/Now.astro";
import Globe from "../components/Globe";
import NowPlayingCard from "../components/NowPlayingCard.astro";
import ProtectedImage from "../components/ProtectedImage.astro";
import ProjectsCard from "../components/ProjectsCard.astro";
import { SITE } from "../site-config";
---

<script>
  import { stagger, animate, type AnimationSequence } from "motion";
  import { loaderAnimation } from "../lib/constants";
  const cards = document.querySelectorAll(".card");

  const sequence = [
    loaderAnimation,
    [
      cards,
      { y: ["40%", "0%"], opacity: [0, 1] },
      {
        type: "spring",
        at: "-0.1",
        delay: stagger(0.2),
      },
    ],
  ];

  animate(sequence as AnimationSequence);
</script>

<Layout
  description={`Chengxi / Daanawa - 一名来自 China Mainland 的废物萌新。08年，坐标北京，高三 Gap year。社会学预备役，业余写码，Minecraft 玩家。`}
  title={`Chengxi / Daanawa - 一名来自 China Mainland 的废物萌新`}
>
  <main
    class="text-white m-auto p-2 grid gap-2 max-w-6xl relative w-full sm:p-4 sm:gap-2 md:grid-cols-2 md:gap-3 md:p-6 lg:h-screen lg:grid-rows-8 lg:grid-cols-4 lg:gap-4 lg:max-h-[800px] lg:overflow-hidden"
  >
    <IntroCard />
    <AboutMe />
    <NowPlayingCard />
    <ProjectsCard />
    <ContactsCard />
    <Now />
    <TimeZone />
    <Card
      colorText="text-neutral-900"
      colSpan="md:col-span-1"
      href="travel"
      rowSpan="md:row-span-1"
      title="我去过的地区"
    >
      <div class="h-full w-full absolute inset-0 -z-10">
        <div class="hidden md:block h-full w-full">
          <Globe client:media="(min-width: 768px)" />
        </div>
        <div class="block md:hidden h-full w-full">
          <Globe client:media="(max-width: 768px)" isStatic={true} />
        </div>
      </div>
    </Card>
    <!-- ThemeChangeCard - 移动端自然流式排列，桌面端定位到第3列第8行 -->
    <div class="lg:col-start-3 lg:row-start-8">
      <ThemeChangeCard />
    </div>

    <!-- 我的OC卡片 - 移动端自然流式排列，桌面端定位到第4列第5-8行 -->
    <div class="lg:col-start-4 lg:row-start-5 lg:row-span-4">
      <Card colSpan="md:col-span-1" rowSpan="md:row-span-4" padding="p-4" title="我的OC">
        <ProtectedImage src="/oc/4k.png" alt="OC" maxLongEdge={540} />
      </Card>
    </div>
  </main>

  <footer class="text-center text-xs text-darkslate-300 -mt-2 pb-4">
    ——© 2026 · 用 ♥️ 和 <a class="text-red-500" href="https://astro.build/" target="_blank">Astro</a> 构建——
  </footer>
</Layout>
